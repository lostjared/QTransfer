####### Compile

main.o: ../main.cpp ../transfer_window.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o ../main.cpp

transfer_window.o: ../transfer_window.cpp ../transfer_window.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o transfer_window.o ../transfer_window.cpp

moc_transfer_window.o: moc_transfer_window.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_transfer_window.o moc_transfer_window.cpp

